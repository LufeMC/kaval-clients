{
  "name": "@usekaval/kaval",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "description": "Evidence gates for AI agents: product research, review-only offer evidence, and action-bound decisions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kaval",
    "ai",
    "agents",
    "evidence",
    "commerce",
    "freshness",
    "rag",
    "verification"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/LufeMC/kaval-clients/tree/main/sdks/node#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LufeMC/kaval-clients.git",
    "directory": "sdks/node"
  },
  "bugs": {
    "url": "https://github.com/LufeMC/kaval-clients/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
